{
  "name": "muonroi-cli",
  "workspaces": [
    "packages/*"
  ],
  "version": "1.2.3",
  "description": "BYOK AI coding agent with multi-model council debate, role-based routing, and auto-compact.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "muonroi-cli": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/models/catalog.json', 'dist/models/catalog.json')\"",
    "build:binary": "bun build --compile --outfile ./dist/muonroi-cli-standalone ./src/index.ts",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "test:harness": "bunx vitest -c vitest.harness.config.ts run tests/harness/",
    "test:core": "bunx vitest run packages/agent-harness-core/__tests__/",
    "test:harness-react": "bunx vitest -c packages/agent-harness-react/vitest.config.ts run",
    "test:harness-angular": "bunx vitest -c vitest.harness-angular.config.ts run tests/harness-angular/",
    "test:angular": "bunx vitest -c packages/agent-harness-angular/vitest.config.ts run",
    "build:core": "cd packages/agent-harness-core && bun run build",
    "lint": "biome check src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "lint:fix": "biome check --fix src/",
    "lint:semantic": "bun scripts/check-semantic-wrap.ts",
    "pre-commit": "lint-staged",
    "prepare": "husky",
    "postinstall": "bun run scripts/postinstall.ts",
    "ee:ingest-bb": "bun run scripts/ingest-bb-to-ee.mts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json}": "biome check --write --no-errors-on-unmatched --max-diagnostics=200"
  },
  "files": [
    "src/",
    "dist/"
  ],
  "keywords": [
    "cli",
    "agent",
    "ai",
    "coding",
    "terminal",
    "opentui"
  ],
  "author": "muonroi",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.72",
    "@ai-sdk/google": "3.0.65",
    "@ai-sdk/mcp": "1.0.37",
    "@ai-sdk/openai": "3.0.54",
    "@ai-sdk/openai-compatible": "2.0.42",
    "@ai-sdk/provider": "3.0.9",
    "@ai-sdk/provider-utils": "4.0.24",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@npmcli/arborist": "^9.4.3",
    "@opentui/core": "0.1.107",
    "@opentui/react": "0.1.107",
    "@qdrant/js-client-rest": "1.17.0",
    "ai": "6.0.169",
    "commander": "^12.1.0",
    "diff": "^8.0.3",
    "fast-xml-parser": "^4.4.1",
    "gpt-tokenizer": "^3.4.0",
    "keytar": "^7.9.0",
    "ollama-ai-provider-v2": "1.5.5",
    "proper-lockfile": "^4.1.2",
    "react": "19.2.5",
    "ripgrep": "^0.3.1",
    "semver": "^7.7.4",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "vscode-jsonrpc": "8.2.1",
    "vscode-languageserver-types": "3.17.5",
    "web-tree-sitter": "0.26.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/diff": "^8.0.0",
    "@types/node": "^22.19.15",
    "@types/npmcli__arborist": "^6.3.3",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.14",
    "@types/semver": "^7.7.1",
    "ajv": "^8.20.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "bun": ">=1.3.13",
    "node": ">=20.0.0"
  },
  "preferGlobal": true
}
