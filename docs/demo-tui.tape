# muonroi-cli TUI demo
# Generate: vhs docs/demo-tui.tape

Output docs/demo-tui.gif

Set Shell "powershell"
Set FontSize 14
Set FontFamily "Consolas"
Set Width 1100
Set Height 600
Set Theme "Dracula"
Set Padding 20
Set PlaybackSpeed 1.0

Type "powershell -ExecutionPolicy Bypass -File docs/demo-tui.ps1"
Enter
Sleep 22s
