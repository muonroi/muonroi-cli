# muonroi-cli council demo
# Generate: vhs docs/demo.tape

Output docs/demo.gif

Set Shell "powershell"
Set FontSize 14
Set FontFamily "Consolas"
Set Width 1100
Set Height 600
Set Theme "Dracula"
Set Padding 20
Set PlaybackSpeed 1.0

Type "powershell -ExecutionPolicy Bypass -File docs/demo.ps1"
Enter
Sleep 22s
